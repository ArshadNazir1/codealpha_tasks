<!DOCTYPE html>
<html>
<head>
    <title>Simple Gallery</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<h2>My Image Gallery</h2>

<div class="gallery">
      <img src="images/img1.jpg">
</div>

<div id="popup">
    <span onclick="closeImage()">X</span>
    <img id="popup-img">
    <br>
    <button onclick="prev()">Prev</button>
    <button onclick="next()">Next</button>
</div>

<script src="script.js"></script>

</body>
</html>



body {
    text-align: center;
    font-family: Arial;
}

.gallery img {
    width: 200px;
    margin: 10px;
    cursor: pointer;
    transition: 0.3s;
}

.gallery img:hover {
    transform: scale(1.1);
}

#popup {
    display: none;
    position: fixed;
    top: 0;
    width: 100%;
    height: 100%;
    background: black;
}

#popup img {
    margin-top: 50px;
    width: 60%;
}

span {
    color: white;
    font-size: 30px;
    cursor: pointer;
}




let images = document.querySelectorAll(".gallery img");
let index = 0;

function openImage(img) {
    document.getElementById("popup").style.display = "block";
    document.getElementById("popup-img").src = img.src;

    index = Array.from(images).indexOf(img);
}

function closeImage() {
    document.getElementById("popup").style.display = "none";
}

function next() {
    index++;
    if (index >= images.length) index = 0;

    document.getElementById("popup-img").src = images[index].src;
}

function prev() {
    index--;
    if (index < 0) index = images.length - 1;

    document.getElementById("popup-img").src = images[index].src;
}
